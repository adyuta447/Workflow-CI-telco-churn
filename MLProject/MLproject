name: telco_churn_mlproject

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      train_path: {type: str, default: "telco_customer_churn_preprocessing/train.csv"}
      test_path: {type: str, default: "telco_customer_churn_preprocessing/test.csv"}
      n_estimators: {type: int, default: 200}
    command: "python modelling.py --train_path {train_path} --test_path {test_path} --n_estimators {n_estimators}"
